APP_NAME="Voz & Cifra"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=COLOCAR_HOST_DO_NEON
DB_PORT=5432
DB_DATABASE=COLOCAR_DATABASE
DB_USERNAME=COLOCAR_USUARIO
DB_PASSWORD=COLOCAR_SENHA
DB_SCHEMA=public
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
PUBLIC_UPLOADS_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_TIMEOUT=10
MAIL_AUTO_TLS=true
# Para provedores com SSL implicito, use MAIL_SCHEME=ssl e MAIL_PORT=465
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
NOTIFICACOES_SEGURANCA_ATIVAS=false
NOTIFICACOES_EVENTOS_HABILITADOS="reset_senha,conta_inativada,conta_reativada,troca_nivel_global,papel_local_concedido,papel_local_revogado"
NOTIFICACOES_ACESSO_INICIAL_ATIVAS=true
NOTIFICACOES_ACESSO_INICIAL_CC=
NOTIFICACOES_SISTEMA_ATIVAS=false
NOTIFICACOES_SISTEMA_EVENTOS_HABILITADOS="acorde_cadastrado,musica_inativada,acorde_inativado,acordes_marco_alcancado,aviso_admin"
NOTIFICACOES_EMAIL_CC_ADMIN=
NOTIFICACOES_CANAL_SUPORTE="suporte oficial do sistema"
NOTIFICACOES_CANAL_SUPORTE_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ADMIN_MASTER_NOME="Administrador Master"
ADMIN_MASTER_CPF=00000000000
ADMIN_MASTER_EMAIL=admin@vozecifra.com
ADMIN_MASTER_TELEFONE=
ADMIN_MASTER_PASSWORD=admin123456
ADMIN_MASTER_NIVEL_GLOBAL=6
ADMIN_MASTER_PRIMEIRO_ACESSO=false

VITE_APP_NAME="${APP_NAME}"
